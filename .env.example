# Docker Compose 配置。请复制为 .env，或直接运行 ./deploy.sh 自动生成随机密钥。
WEB_PORT=3000

POSTGRES_USER=canvas
POSTGRES_PASSWORD=replace-with-a-random-database-password
POSTGRES_DB=canvas

REDIS_PASSWORD=replace-with-a-random-redis-password
REDIS_DB=0

# JWT_SECRET 至少 32 字节；CHANNEL_ENC_KEY 必须是 64 位 hex。
JWT_SECRET=replace-with-a-long-random-jwt-secret
CHANNEL_ENC_KEY=replace-with-64-hex-characters
ACCESS_TOKEN_TTL=1h
REFRESH_TOKEN_TTL=720h

CORS_ORIGINS=http://localhost:3000
ALLOW_REGISTRATION=true

# 邮箱和对象存储不写入此文件；首次部署后登录管理员后台配置。

# 可选网站统计，留空即关闭。
ANALYTICS_GA4_ID=
ANALYTICS_BAIDU_ID=
