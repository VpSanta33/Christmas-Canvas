# Docker Compose 默认值。开发环境可直接执行 docker compose up --build -d；
# 复制为 .env 后可覆盖端口、凭据和生产配置。
WEB_PORT=3000
MAILPIT_WEB_PORT=8025
MINIO_CONSOLE_PORT=9001

POSTGRES_USER=canvas
POSTGRES_PASSWORD=canvas
POSTGRES_DB=canvas

REDIS_PASSWORD=
REDIS_DB=0

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_BUCKET=canvas
S3_REGION=us-east-1

# 生产环境必须替换。JWT_SECRET 至少 32 字节；CHANNEL_ENC_KEY 必须是 64 位 hex。
JWT_SECRET=change-me-in-production-at-least-32-bytes
CHANNEL_ENC_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
ACCESS_TOKEN_TTL=1h
REFRESH_TOKEN_TTL=720h

CORS_ORIGINS=http://localhost:3000
ALLOW_REGISTRATION=true
REGISTER_GRANT_CREDITS=100

# 本地默认通过 Mailpit 验证邮箱；生产环境应改用真实 SMTP 和 TLS。
EMAIL_VERIFICATION_ENABLED=true
EMAIL_VERIFICATION_TTL=10m
EMAIL_VERIFICATION_COOLDOWN=60s
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_MODE=none
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@canvas.local
SMTP_FROM_NAME=圣诞AI画布

# 可选网站统计，留空即关闭。
ANALYTICS_GA4_ID=
ANALYTICS_BAIDU_ID=
