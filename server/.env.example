# HTTP / 数据库 / Redis
APP_ADDR=:8080
DATABASE_URL=postgres://canvas:canvas@localhost:5432/canvas?sslmode=disable
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
CORS_ORIGINS=http://localhost:3000

# 生产环境必须使用随机值：JWT_SECRET 至少 32 字节；CHANNEL_ENC_KEY 必须是 64 位 hex。
JWT_SECRET=replace-with-a-long-random-secret
CHANNEL_ENC_KEY=replace-with-64-hex-characters
ACCESS_TOKEN_TTL=1h
REFRESH_TOKEN_TTL=720h

# 注册策略。ALLOW_REGISTRATION 只在后台尚未保存站点设置时作为回退值。
ALLOW_REGISTRATION=true

# 邮箱和对象存储不写入此文件；首次启动后登录管理员后台配置。
# SMTP_*、S3_* 和 STORAGE_* 仍支持作为旧部署的可选环境回退，但不建议新部署使用。
