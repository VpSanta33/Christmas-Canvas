# HTTP / 数据库 / Redis
APP_ADDR=:8080
DATABASE_URL=postgres://canvas:canvas@localhost:5432/canvas?sslmode=disable
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
CORS_ORIGINS=http://localhost:3000

# 生产环境必须重新生成：JWT_SECRET 建议至少 32 字节；CHANNEL_ENC_KEY 必须是 64 位 hex。
JWT_SECRET=replace-with-a-long-random-secret
CHANNEL_ENC_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
ACCESS_TOKEN_TTL=1h
REFRESH_TOKEN_TTL=720h

# MinIO / S3
STORAGE_ENABLED=true
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=canvas
S3_REGION=us-east-1
S3_USE_SSL=false
STORAGE_PATH_PREFIX=
STORAGE_IMAGE_PATH_PREFIX=image
STORAGE_VIDEO_PATH_PREFIX=Video
PUBLIC_FILE_BASE_URL=/api/files/

# 注册与邮箱验证。开发环境配合 docker compose 的 Mailpit 使用。
ALLOW_REGISTRATION=true
REGISTER_GRANT_CREDITS=100
EMAIL_VERIFICATION_ENABLED=true
EMAIL_VERIFICATION_TTL=10m
EMAIL_VERIFICATION_COOLDOWN=60s
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_MODE=none
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@canvas.local
SMTP_FROM_NAME=圣诞画布
