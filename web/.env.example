# 前端环境变量样例。复制为 .env 或 .env.local 后修改。
# 优先级：容器运行时 window.__RUNTIME_CONFIG__ > 构建期 VITE_ 变量 > 代码默认值。

# 运行模式：backend（默认，接入 server/ 后端）| local（显式启用的免登录本地模式）
VITE_APP_MODE=backend

# backend 模式下的后端地址（含 /api 前缀）。local 模式忽略。
# 与 server 同机开发时通常为 http://localhost:8080/api；Docker 部署使用 /api。
VITE_API_BASE_URL=http://localhost:8080/api

# 可选：文档站地址
# VITE_DOC_URL=

# 可选：官方插件注册表地址
# VITE_PLUGIN_REGISTRY_URL=

# 可选：开发期额外加载的插件（逗号分隔）
# VITE_DEV_PLUGINS=

# 可选：站点分析
# VITE_ANALYTICS_GA=
# VITE_ANALYTICS_BAIDU_ID=
